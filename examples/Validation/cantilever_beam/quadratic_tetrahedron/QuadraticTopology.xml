<Node name="Group">
    <Node name="preprocessing">
        <RegularGridTopology name="grid" min="-0.01 -0.01 0" max="0.01 0.01 0.2" n="3 3 20" computeTriangleList="false"/>
        <MechanicalObject name="state" template="Vec3"/>

        <Node name="tetrahedra">
            <TetrahedronSetTopologyContainer name="Tetra_topo"/>
            <Hexa2TetraTopologicalMapping input="@../grid" output="@Tetra_topo" swapping="true"/>

            <LinearToHigherOrderElements name="engine" computeFromEdges="false" computeFromTriangles="false" computeFromQuads="false"/>
        </Node>
    </Node>
</Node>
