# We can't use CUDA on the build slaves, so let's just ignore the scenes that
# use the SofaCUDA plugin.
ignore "beam10x10x46-warp-preconditioner-CUDA.scn"
ignore "CudaDiagonalMass3f.scn"
ignore "CudaMeshMatrixMass3f.scn"
ignore "CudaTetrahedronTLEDForceField.scn"
ignore "liver-CUDA.scn"
ignore "quadSelfCollisCUDA.scn"
ignore "quadSpringSphere2CUDA.scn"

iterations "raptor-cpu.scn" "10"
timeout "raptor-cpu.scn" "60"
ignore "raptor-cuda.scn"
ignore "raptor.scn"

iterations "raptor-surface-cpu.scn" "10"
timeout "raptor-surface-cpu.scn" "60"
ignore "raptor-surface-cuda.scn"

ignore "SPHFluid2CUDA.scn"
ignore "SPHFluidForceFieldCUDA.scn"

iterations "SquareTissue-cpu.scn" "10"
timeout "SquareTissue-cpu.scn" "60"
ignore "SquareTissue-cuda.scn"

iterations "StandardTetrahedralFEMForceFieldCPU.scn" "10"
timeout "StandardTetrahedralFEMForceFieldCPU.scn" "60"
ignore "StandardTetrahedralFEMForceFieldCUDA.scn"

iterations "TetrahedralTensorMassForceFieldCPU.scn" "10"
timeout "TetrahedralTensorMassForceFieldCPU.scn" "60"
ignore "TetrahedralTensorMassForceFieldCUDA.scn"
ignore "TetrahedronFEM_with_SpringForceField.scn"

ignore "CudaCorotationalFEMForceField.scn"
ignore "CudaLinearSmallStrainFEMForceField.scn"
ignore "CudaCorotationalFEMForceField_hexa.scn"
ignore "CudaCorotationalFEMForceField_quad.scn"
ignore "CudaCorotationalFEMForceField_tetra.scn"
ignore "CudaCorotationalFEMForceField_triangle.scn"
ignore "CudaCorotationalFEMForceField_prism.scn"
ignore "CudaCorotationalFEMForceField_pyramid.scn"
ignore "CudaLinearSmallStrainFEMForceField_hexa.scn"
ignore "CudaLinearSmallStrainFEMForceField_quad.scn"
ignore "CudaLinearSmallStrainFEMForceField_tetra.scn"
ignore "CudaLinearSmallStrainFEMForceField_triangle.scn"
ignore "CudaLinearSmallStrainFEMForceField_prism.scn"
ignore "CudaLinearSmallStrainFEMForceField_pyramid.scn"
ignore "CorotationalFEMForceField_tetra_cpu_gpu.scn"
ignore "Tetrahedron_corotational.py"
ignore "Hexahedron_corotational.py"
